{
  "name": "task-system-app",
  "version": "0.0.1",
  "description": "Standalone real-world task system example for nestjs-yalc",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"apps/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/task-system-app/main",
    "lint": "cd ../../.. && find examples/task/app/apps/task-system-app/src -name '*.ts' ! -name '*.spec.ts' -print0 | xargs -0 -n 10 env NODE_OPTIONS=--max-old-space-size=4096 eslint -c .eslintrc.cjs --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --config ./jest.config.json --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "NODE_OPTIONS=\"--experimental-vm-modules --experimental-import-meta-resolve \" jest --config ./apps/task-system-app/test/jest-e2e.json",
    "test:e2e:rabbitmq": "NODE_OPTIONS=\"--experimental-vm-modules --experimental-import-meta-resolve \" jest --config ./apps/task-system-app/test/jest-rabbitmq-e2e.json",
    "test:e2e:observability": "NODE_OPTIONS=\"--experimental-vm-modules --experimental-import-meta-resolve \" jest --config ./apps/task-system-app/test/jest-observability-e2e.json",
    "rabbitmq:up": "docker compose -f docker-compose.rabbitmq.yml up -d --wait",
    "rabbitmq:down": "docker compose -f docker-compose.rabbitmq.yml down",
    "observability:up": "docker compose -f docker-compose.observability.yml up -d",
    "observability:down": "docker compose -f docker-compose.observability.yml down",
    "observability:ci:up": "docker compose -f docker-compose.observability-ci.yml up -d",
    "observability:ci:down": "docker compose -f docker-compose.observability-ci.yml down"
  },
  "dependencies": {
    "@fastify/static": "^6.12.0",
    "@fastify/view": "^7.4.1",
    "@nestjs-yalc/api-strategy": "^1.3.2",
    "@nestjs-yalc/app": "^1.3.2",
    "@nestjs-yalc/crud-gen": "^1.3.2",
    "@nestjs-yalc/data-loader": "^1.3.2",
    "@nestjs-yalc/database": "^1.3.2",
    "@nestjs-yalc/errors": "^1.3.2",
    "@nestjs-yalc/event-manager": "^1.3.2",
    "@nestjs-yalc/field-middleware": "^1.3.2",
    "@nestjs-yalc/framework": "^1.3.2",
    "@nestjs-yalc/graphql": "^1.3.2",
    "@nestjs-yalc/interfaces": "^1.3.2",
    "@nestjs-yalc/jest": "^1.3.2",
    "@nestjs-yalc/logger": "^1.3.2",
    "@nestjs-yalc/observability": "^1.3.2",
    "@nestjs-yalc/omnikernel-module": "file:../omnikernel-module",
    "@nestjs-yalc/task-system-module": "file:../module",
    "@nestjs-yalc/types": "^1.3.2",
    "@nestjs-yalc/utils": "^1.3.2",
    "@nestjs/axios": "^1.0.1",
    "@nestjs/common": "^9.4.3",
    "@nestjs/core": "^9.4.3",
    "@nestjs/event-emitter": "^1.4.1",
    "@nestjs/graphql": "^10.2.1",
    "@nestjs/mercurius": "^10.2.1",
    "@nestjs/platform-express": "^9.4.3",
    "@nestjs/platform-fastify": "^9.4.3",
    "@nestjs/typeorm": "^9.0.1",
    "amqplib": "^0.10.9",
    "axios": "^1.15.0",
    "graphql": "^16.12.0",
    "mercurius": "^10.5.1",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^4.1.2",
    "rxjs": "^7.8.0",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.14"
  },
  "devDependencies": {
    "@nestjs/cli": "^9.5.0",
    "@nestjs/schematics": "^9.0.4",
    "@nestjs/testing": "^9.4.3",
    "@types/amqplib": "^0.10.8",
    "@types/express": "^4.17.16",
    "@types/jest": "29.2.6",
    "@types/node": "^18.11.18",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^5.49.0",
    "@typescript-eslint/parser": "^5.49.0",
    "eslint": "^8.32.0",
    "eslint-config-prettier": "^8.6.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^29.4.0",
    "prettier": "^2.8.3",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.0.5",
    "ts-loader": "^9.4.2",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.1.2",
    "typescript": "^4.9.4"
  }
}
